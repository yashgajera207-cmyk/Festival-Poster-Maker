generator client {
provider = "prisma-client-js"
}

datasource db {
provider = "postgresql"
url      = env("DATABASE_URL")
}

enum Role {
ADMIN
USER
}

model User {
  id String @id @default(uuid())

  businessName String
  email String @unique
  mobile String
  address String
  logoUrl String
  password String
  role Role @default(USER)
  refreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generatedPosters GeneratedPoster[]
  userPosterLayouts UserPosterLayout[]
}
model Category {
id        String   @id @default(uuid())
name      String
slug      String   @unique

createdAt DateTime @default(now())

templates Template[]
}

model Template {
  id String @id @default(uuid())

  title String
  backgroundImage String

  categoryId String
  category Category @relation(fields: [categoryId], references: [id])

  elements TemplateElement[]

  generatedPosters GeneratedPoster[]

  userPosterLayouts UserPosterLayout[]

  createdAt DateTime @default(now())
}

model TemplateElement {
id          String   @id @default(uuid())

templateId  String

elementType String

xPosition   Int
yPosition   Int

width       Int
height      Int
fontSize   Int?
fontWeight String?
textColor  String?

createdAt   DateTime @default(now())

template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}


model GeneratedPoster {
id String @id @default(uuid())

userId String
user   User @relation(fields: [userId], references: [id])

templateId String
template   Template @relation(fields: [templateId], references: [id])

companyName String?
logoUrl     String?
address     String?
phone       String?
email       String?

generatedImage String?

createdAt DateTime @default(now())
}

model UserPosterLayout {
  id String @id @default(uuid())

  userId String
  templateId String

  elementType String

  xPosition Int
  yPosition Int

  width Int
  height Int

  fontSize Int?
  fontWeight String?
  textColor String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  template Template @relation(fields: [templateId], references: [id])
}